<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.masanz.da.juegored.client.controller.HostConfigController">
    <top>
        <BorderPane prefHeight="119.0" prefWidth="665.0" style="-fx-background-color: #353535;" BorderPane.alignment="CENTER">
            <center>
                <ImageView fitHeight="100.0" fitWidth="600.0" pickOnBounds="true" BorderPane.alignment="CENTER">
                    <image>
                        <Image url="@../imgs/logo.png" />
                    </image>
                </ImageView>
            </center>
        </BorderPane>
    </top>
    <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#cancelarHostConfig" text="Cancelar" />
            <Button mnemonicParsing="false" onAction="#crearSala" text="Crear sala" />
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Label alignment="CENTER_RIGHT" prefWidth="140.0" text="Nombre de sala:" textAlignment="RIGHT" />
                  <TextField fx:id="txtSala" maxWidth="200.0" prefWidth="200.0" text="Hola Mundo" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Label alignment="CENTER_RIGHT" prefWidth="140.0" text="Número de jugadores:" textAlignment="RIGHT" />
                  <TextField fx:id="numJugadores" prefWidth="200.0" text="3" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Label alignment="CENTER_RIGHT" prefWidth="140.0" text="Tipo de sala:" textAlignment="RIGHT" />
                  <HBox alignment="CENTER" fillHeight="false" prefWidth="200.0">
                     <children>
                        <RadioButton fx:id="rbtPublic" mnemonicParsing="false" prefWidth="100.0" selected="true" text="Pública">
                           <toggleGroup>
                              <ToggleGroup fx:id="tipo" />
                           </toggleGroup></RadioButton>
                        <RadioButton fx:id="rbtPrivate" mnemonicParsing="false" prefWidth="100.0" text="Privada" toggleGroup="$tipo" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" />
            <HBox alignment="CENTER" layoutX="10.0" layoutY="275.0" prefHeight="100.0" prefWidth="200.0" spacing="10.0" />
         </children>
         <BorderPane.margin>
            <Insets top="10.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
