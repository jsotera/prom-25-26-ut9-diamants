            <Button mnemonicParsing="false" text="Cancelar" visible="false" BorderPane.alignment="CENTER" />
         </left>
      </BorderPane>
   </bottom>
   <left>
      <TableView fx:id="tvPlayers" prefHeight="225.0" prefWidth="285.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNombre" editable="false" prefWidth="195.0" resizable="false" sortable="false" text="Jugador" />
