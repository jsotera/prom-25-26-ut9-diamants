            <Button fx:id="btnEstoyListo" mnemonicParsing="false" onAction="#estoyListo" text="¡Estoy Listo!" BorderPane.alignment="CENTER" />
         </center>
         <right>
            <Button mnemonicParsing="false" onAction="#cancelar" text="Cancelar" BorderPane.alignment="CENTER" />
