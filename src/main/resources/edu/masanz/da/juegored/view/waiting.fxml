                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextArea>
            <HBox maxWidth="1.7976931348623157E308" prefWidth="250.0">
               <children>
                  <TextField fx:id="txtUserChat" maxWidth="1.7976931348623157E308" onAction="#enviar" promptText="Habla con tus compis..." HBox.hgrow="ALWAYS">
