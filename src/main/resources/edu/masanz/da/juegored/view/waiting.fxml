<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.masanz.da.juegored.client.controller.WaitingController">
   <top>
      <BorderPane prefHeight="119.0" prefWidth="665.0" style="-fx-background-color: #353535;" BorderPane.alignment="CENTER">
